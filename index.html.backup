<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Récap Prune Partenaires 2026 — This Is It Event | Expérience Premium</title>
    <link rel="icon" type="image/png" href="images/test.png">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        noir: '#0A0A0A',
                        blanc: '#F5F2EC',
                        rouge: '#E8281E',
                        or: '#C9A84C',
                        gris: '#1A1A1A',
                        'gris-mid': '#2E2E2E',
                        'gris-light': '#888',
                        'vert-proof': '#2D7D46',
                        'glass-dark': 'rgba(15, 23, 42, 0.8)',
                        'glass-light': 'rgba(255, 255, 255, 0.1)',
                        'lime': '#D2FF00', // Inspiré de Lando Norris
                        'dark-green': '#101400' // Inspiré de Lando Norris
                    },
                    fontFamily: {
                        'bebas': ['Bebas Neue', 'sans-serif'],
                        'dm-sans': ['DM Sans', 'sans-serif'],
                        'dm-mono': ['DM Mono', 'monospace'],
                        'geist': ['Geist', 'system-ui', 'sans-serif'],
                        'mona': ['Mona Sans', 'system-ui', 'sans-serif'] // Inspiré de Lando Norris
                    },
                    backdropBlur: {
                        'xs': '2px',
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.8s ease-out',
                        'slide-up': 'slideUp 0.6s ease-out',
                        'slide-down': 'slideDown 0.6s ease-out',
                        'slide-left': 'slideLeft 0.6s ease-out',
                        'slide-right': 'slideRight 0.6s ease-out',
                        'pulse-glow': 'pulseGlow 2s infinite',
                        'count-up': 'countUp 2s ease-out forwards',
                        'float': 'float 3s ease-in-out infinite' // Nouvelle animation
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' }
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' }
                        },
                        slideDown: {
                            '0%': { transform: 'translateY(-20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' }
                        },
                        slideLeft: {
                            '0%': { transform: 'translateX(20px)', opacity: '0' },
                            '100%': { transform: 'translateX(0)', opacity: '1' }
                        },
                        slideRight: {
                            '0%': { transform: 'translateX(-20px)', opacity: '0' },
                            '100%': { transform: 'translateX(0)', opacity: '1' }
                        },
                        pulseGlow: {
                            '0%, 100%': { boxShadow: '0 0 20px rgba(232, 40, 30, 0.3)' },
                            '50%': { boxShadow: '0 0 40px rgba(232, 40, 30, 0.6)' }
                        },
                        countUp: {
                            '0%': { content: '"0"' },
                            '100%': { content: 'attr(data-target)' }
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0px)' },
                            '50%': { transform: 'translateY(-10px)' }
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- AOS (Animate On Scroll) - version allégée -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    
    <!-- Fonts optimisées -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome Icons - version allégée -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom Styles inspirés de Lando Norris -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            /* Variables CSS inspirées de Lando Norris */
            --cubic-default: cubic-bezier(0.65, 0.05, 0, 1);
            --duration-default: 0.75s;
            --animation-default: var(--duration-default) var(--cubic-default);
            --section-padding: calc(3.5rem + (var(--gap) * 2));
            --container-padding: 2rem;
            --nav-height: calc(3.75rem + (var(--gap) * 2));
            
            /* Scaling fluide */
            --min-width: 320px;
            --max-width: 1920px;
            --design-width: 1728;
            --design-unit: 16;
            --scale-factor: 1;
            
            /* Couleurs inspirées de Lando Norris */
            --color-dark-green: #101400;
            --color-lime: #D2FF00;
            --color-black: #0A0A0A;
            --color-white: #F5F2EC;
            --color-red: #E8281E;
            --color-gold: #C9A84C;
            --color-green: #2D7D46;
        }
        
        html {
            scroll-behavior: smooth;
            font-size: calc(var(--fluid-container) / var(--design-width) * var(--design-unit) * var(--scale-factor));
        }
        
        body {
            font-family: 'Inter', 'DM Sans', sans-serif;
            background: var(--color-dark-green);
            color: var(--color-white);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        /* Glassmorphism effect amélioré */
        .glass-card {
            background: rgba(16, 20, 0, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(210, 255, 0, 0.1);
            border-radius: 20px;
            transition: all 0.3s var(--cubic-default);
        }
        
        .glass-card:hover {
            border-color: rgba(210, 255, 0, 0.3);
            transform: translateY(-2px);
        }
        
        /* Gradient text amélioré */
        .gradient-text {
            background: linear-gradient(90deg, var(--color-red) 0%, var(--color-gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .gradient-text-lime {
            background: linear-gradient(90deg, var(--color-lime) 0%, var(--color-gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* Custom scrollbar amélioré */
        ::-webkit-scrollbar {
            width: 10px;
        }
        
        ::-webkit-scrollbar-track {
            background: rgba(16, 20, 0, 0.5);
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--color-red) 0%, var(--color-lime) 100%);
            border-radius: 5px;
        }
        
        /* Section spacing amélioré */
        .section-spacing {
            padding-top: 8rem;
            padding-bottom: 8rem;
        }
        
        @media (max-width: 768px) {
            .section-spacing {
                padding-top: 5rem;
                padding-bottom: 5rem;
            }
        }
        
        /* KPI counter animation améliorée */
        .kpi-counter {
            font-variant-numeric: tabular-nums;
            font-feature-settings: 'tnum';
        }
        
        /* Navigation améliorée inspirée de Lando Norris */
        .nav-link {
            position: relative;
            padding: 0.5rem 1rem;
            transition: all 0.3s var(--cubic-default);
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            width: 0;
            height: 2px;
            background: var(--color-lime);
            transition: all 0.3s var(--cubic-default);
            transform: translateX(-50%);
        }
        
        .nav-link:hover::after {
            width: 80%;
        }
        
        .nav-link.active::after {
            width: 100%;
            background: var(--color-red);
        }
        
        /* Bouton CTA amélioré */
        .cta-button {
            background: linear-gradient(90deg, var(--color-red) 0%, var(--color-gold) 100%);
            color: var(--color-white);
            padding: 1rem 2.5rem;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s var(--cubic-default);
            position: relative;
            overflow: hidden;
            border: none;
        }
        
        .cta-button::before {
            content: '';
            position: absolute;
            top: 0%;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.7s;
        }
        
        .cta-button:hover::before {
            left: 100%;
        }
        
        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(232, 40, 30, 0.3);
        }
        
        /* Progress bar améliorée */
        .progress-bar {
            height: 3px;
            background: linear-gradient(90deg, var(--color-red) 0%, var(--color-lime) 100%);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 9999;
            transition: width 0.3s ease;
        }
        
        /* Animation float */
        .float-animation {
            animation: float 3s ease-in-out infinite;
        }
        
        /* Grid amélioré pour les KPI */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }
        
        /* Typographie améliorée */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -0.02em;
        }
        
        /* Responsive amélioré */
        @media (max-width: 640px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }
            
            .section-spacing {
                padding-top: 4rem;
                padding-bottom: 4rem;
            }
        }
        
        /* Effet de parallaxe léger */
        .parallax-bg {
            background-attachment: fixed;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
        }
        
        /* Transition entre sections */
        .section-transition {
            position: relative;
            overflow: hidden;
        }
        
        .section-transition::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--color-lime), transparent);
        }
    </style>
</head>
<body class="bg-dark-green text-white">
    <!-- Progress Bar améliorée -->
    <div class="progress-bar" id="progressBar"></div>
    
    <!-- Navigation améliorée inspirée de Lando Norris -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-dark-green/95 backdrop-blur-md border-b border-lime/10 py-4 px-6">
        <div class="container mx-auto flex justify-between items-center">
            <!-- Logo amélioré -->
            <div class="flex items-center space-x-3 group cursor-pointer">
                <div class="w-10 h-10 bg-gradient-to-br from-rouge to-lime rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
                    <span class="text-black font-bebas text-lg font-bold">TII</span>
                </div>
                <div>
                    <span class="font-bebas text-2xl text-white">THIS IS IT</span>
                    <span class="font-dm-mono text-xs text-lime block -mt-1">EVENT</span>
                </div>
            </div>
            
            <!-- Desktop Navigation améliorée -->
            <div class="hidden md:flex space-x-1">
                <a href="#cover" class="nav-link text-slate-300 hover:text-white font-medium">Accueil</a>
                <a href="#chiffres" class="nav-link text-slate-300 hover:text-white font-medium">Chiffres</a>
                <a href="#impact" class="nav-link text-slate-300 hover:text-white font-medium">Impact</a>
                <a href="#digital" class="nav-link text-slate-300 hover:text-white font-medium">Digital</a>
                <a href="#livraison" class="nav-link text-slate-300 hover:text-white font-medium">Livraison</a>
                <a href="#local" class="nav-link text-slate-300 hover:text-white font-medium">Local</a>
                <a href="#scene" class="nav-link text-slate-300 hover:text-white font-medium">Scénographie</a>
                <a href="#cta" class="ml-4 cta-button text-sm">2027</a>
            </div>
            
            <!-- Mobile Menu Button amélioré -->
            <button id="mobileMenuButton" class="md:hidden text-lime w-10 h-10 flex items-center justify-center rounded-lg border border-lime/20 hover:border-lime/40 transition-colors">
                <i class="fas fa-bars text-lg"></i>
            </button>
        </div>
        
        <!-- Mobile Navigation améliorée -->
        <div id="mobileMenu" class="md:hidden absolute top-full left-0 right-0 bg-dark-green/95 backdrop-blur-lg border-t border-lime/10 hidden">
            <div class="flex flex-col space-y-1 p-4">
                <a href="#cover" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Accueil</a>
                <a href="#chiffres" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Chiffres</a>
                <a href="#impact" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Impact</a>
                <a href="#digital" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Digital</a>
                <a href="#livraison" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Livraison</a>
                <a href="#local" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Local</a>
                <a href="#scene" class="nav-link text-slate-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime/5">Scénographie</a>
                <a href="#cta" class="cta-button mt-2 text-center">2027</a>
            </div>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main class="pt-16">
        <!-- Section 1: Cover améliorée -->
        <section id="cover" class="min-h-screen flex items-center justify-center relative overflow-hidden section-spacing section-transition">
            <!-- Background amélioré avec effet parallaxe -->
            <div class="absolute inset-0 bg-gradient-to-br from-dark-green via-black to-gris-mid"></div>
            <div class="absolute inset-0 parallax-bg" style="background-image: url('https://enjoylife-emx.fr/assets/images/image04.jpg?v=a549abeb'); opacity: 0.5;"></div>
            
            <div class="container mx-auto px-4 relative z-10" data-aos="fade-up" data-aos-duration="1000">
                <div class="glass-card p-8 md:p-12 max-w-5xl mx-auto float-animation">
                    <div class="mb-8 text-center">
                        <span class="font-dm-mono text-sm tracking-widest text-lime uppercase">THIS IS IT EVENT — ASSOCIATION LOI 1901</span>
                    </div>
                    
                    <h1 class="font-bebas text-5xl md:text-7xl lg:text-8xl text-white leading-tight mb-6 text-center">
                        RÉCAP<br>
                        <span class="gradient-text-lime">PARTENAIRES</span>
                        <div class="gradient-text-lime">2026</div>
                        <video autoplay muted loop class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none">
                            <source src="videos/testvideo.webm" type="video/webm">
                   </h1>
                    
                    <div class="mt-12 pt-8 border-t border-lime/20">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div>
                                <p class="text-slate-300 font-medium mb-3"><span class="text-white font-bold text-lg">Enjoylife Edition 3</span> — Vendredi 20 Février 2026</p>
                                <p class="text-slate-300 font-medium mb-3"><span class="text-white font-bold text-lg">La Nuit des Amateurs Edition 2</span> — Samedi 21 Février 2026</p>
                                <p class="text-slate-300 font-medium">Centre Innovance · Villieu-Loyes-Mollon (01)</p>
                            </div>
                            <div class="md:text-right">
                                <p class="text-lime font-bold text-lg md:text-xl leading-relaxed">DOUBLE SOLD OUT<br>1 500 SPECTATEURS<br>30 PARTENAIRES</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-12 flex justify-center">
                        <a href="#chiffres" class="cta-button flex items-center space-x-3">
                            <span>Découvrir les résultats</span>
                            <i class="fas fa-arrow-down"></i>
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-rouge via-lime to-vert-proof"></div>
        </section>
        
        <!-- Section 2: Chiffres Clés améliorée -->
        <section id="chiffres" class="section-spacing section-transition">
            <div class="container mx-auto px-4">
                <div class="mb-12 text-center" data-aos="fade-up">
                    <div class="inline-block font-dm-mono text-sm tracking-widest text-lime uppercase mb-4">01</div>
                    <h2 class="font-bebas text-4xl md:text-6xl text-white mb-4">Les chiffres qui parlent</h2>
                    <p class="text-slate-400 max-w-2xl mx-auto">Week-end complet · Centre Innovance · Villieu-Loyes-Mollon</p>
                </div>
                
                <!-- KPI Grid amélioré -->
                <div class="kpi-grid">
                    <!-- KPI 1 -->
                    <div class="glass-card p-6 relative overflow-hidden" data-aos="fade-up" data-aos-delay="100">
                        <div class="absolute top-4 right-4 bg-rouge text-white text-xs font-dm-mono px-3 py-1 rounded-full">SOLD OUT</div>
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Spectateurs</div>
                        <div class="font-bebas text-5xl md:text-6xl text-rouge mb-4 kpi-counter" data-target="1500">0</div>
                        <p class="text-slate-400 text-sm">Week-end complet<br>Les deux soirs à guichets fermés</p>
                    </div>
                    
                    <!-- KPI 2 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="150">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Personnes touchées</div>
                        <div class="font-bebas text-5xl md:text-6xl text-lime mb-4 kpi-counter" data-target="334700">0</div>
                        <p class="text-slate-400 text-sm">Audience unique Facebook & Instagram<br>1,67 M d'impressions publicitaires</p>
                    </div>
                    
                    <!-- KPI 3 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Budget de production</div>
                        <div class="font-bebas text-5xl md:text-6xl text-white mb-4 kpi-counter" data-target="31000">0</div>
                        <p class="text-slate-400 text-sm">Budget équilibré · Zéro dette<br>Gestion rigoureuse certifiée</p>
                    </div>
                    
                    <!-- KPI 4 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="250">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Incidents · Dettes</div>
                        <div class="font-bebas text-5xl md:text-6xl text-vert-proof mb-4">ZÉRO</div>
                        <p class="text-slate-400 text-sm">100% festif · Sécurisé<br>Moyenne d'âge : 36 ans</p>
                    </div>
                    
                    <!-- KPI 5 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Partenaires</div>
                        <div class="font-bebas text-5xl md:text-6xl text-white mb-4 kpi-counter" data-target="30">0</div>
                        <p class="text-slate-400 text-sm">Sponsors & mécènes<br>3 niveaux d'engagement</p>
                    </div>
                    
                    <!-- KPI 6 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="350">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Visites web + billetterie</div>
                        <div class="font-bebas text-5xl md:text-6xl text-white mb-4 kpi-counter" data-target="11000">0</div>
                        <p class="text-slate-400 text-sm">Site officiel + Shotgun<br>durant la campagne</p>
                    </div>
                    
                    <!-- KPI 7 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="400">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Publications réseaux</div>
                        <div class="font-bebas text-5xl md:text-6xl text-white mb-4 kpi-counter" data-target="408">0</div>
                        <p class="text-slate-400 text-sm">Sur 9 mois de campagne<br>Instagram & Facebook</p>
                    </div>
                    
                    <!-- KPI 8 -->
                    <div class="glass-card p-6" data-aos="fade-up" data-aos-delay="450">
                        <div class="font-dm-mono text-xs tracking-widest text-slate-400 uppercase mb-4">Renouvellement 2027</div>
                        <div class="font-bebas text-5xl md:text-6xl text-vert-proof mb-4">100%</div>
                        <p class="text-slate-400 text-sm">Des partenaires recroisés<br>ont confirmé leur retour</p>
                    </div>
                </div>
            </div>
        </section>
        
        
        <!-- Section 3: Impact Global améliorée -->
        <section id="impact" class="section-spacing bg-gradient-to-b from-dark-green to-black section-transition">
            <div class="container mx-auto px-4">
                <div class="mb-12 text-center" data-aos="fade-up">
                    <div class="inline-block font-dm-mono text-sm tracking-widest text-rouge uppercase mb-4">02</div>
                    <h2 class="font-bebas text-4xl md:text-6xl text-white mb-4">Un succès qui dépasse les frontières</h2>
                    <p class="text-slate-400 max-w-2xl mx-auto">Rayonnement territorial · Santé associative · Impact local</p>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <div class="glass-card p-8" data-aos="fade-right">
                        <div class="font-dm-mono text-xs tracking-widest text-lime uppercase mb-6">Fréquentation & Rayonnement</div>
                        
                        <div class="space-y-6">
                            <div class="flex items-start space-x-4">
                                <div class="text-lime text-xl mt-1">▸</div>
                                <div>
                                    <p class="text-white font-medium">1 500 spectateurs réunis sur le week-end</p>
                                    <p class="text-slate-400 text-sm mt-1">Double Sold Out les deux soirs</p>
                                </div>
                            </div>
                            <div class="flex items-start space-x-4">
                                <div class="text-lime text-xl mt-1">▸</div>
                                <div>
                                    <p class="text-white font-medium">Enjoylife : guichets fermés 24h avant l'ouverture</p>
                                    <p class="text-slate-400 text-sm mt-1">+ 200 personnes en liste d'attente</p>
                                </div>
                            </div>
                            <div class="flex items-start space-x-4">
